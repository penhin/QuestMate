APP_NAME=QuestMate
APP_ENV=development
LOG_LEVEL=info
KNOWLEDGE_ADMIN_TOKEN=

ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# Exact HTTPS hosts allowed for caller-owned custom model credentials.
CUSTOM_MODEL_ENDPOINT_HOSTS=

TAVILY_API_KEY=your-tavily-api-key
# Start with `docker compose up -d searxng`; the local backend reaches it here.
SEARXNG_BASE_URL=http://127.0.0.1:8080
SEARXNG_TIMEOUT_SECONDS=12
SEARXNG_MAX_QUERIES_PER_REQUEST=3
SEARCH_PROVIDER_COOLDOWN_SECONDS=120
# Tavily is a fallback after SearXNG/MediaWiki, not the default first wave.
TAVILY_FALLBACK_MAX_CALLS=1

DATABASE_URL=postgresql+asyncpg://questmate:questmate@localhost:5433/questmate
REDIS_URL=redis://localhost:6380/0
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
# Only for local demos: conversations are lost when the process stops.
ALLOW_IN_MEMORY_STORAGE=false
CORS_ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,tauri://localhost

SEARCH_MAX_RESULTS=5
# Full page evidence improves answer grounding; disable only to reduce search cost/latency.
SEARCH_INCLUDE_RAW_CONTENT=true
EVIDENCE_PASSAGE_MAX_CHARS=1600
EXTERNAL_REQUEST_TIMEOUT_SECONDS=20
TAVILY_MAX_CONCURRENCY=3
TAVILY_SEARCH_CACHE_TTL_SECONDS=86400
TAVILY_SEARCH_CACHE_MAX_ENTRIES=512
SEARCH_CACHE_USE_REDIS=true
TAVILY_FIRST_WAVE_QUERIES=2
TAVILY_MAX_QUERIES_PER_REQUEST=2
MEDIAWIKI_DIRECT_SEARCH=true
WIKI_AUTO_INDEX_ENABLED=true
WIKI_AUTO_INDEX_PAGES_PER_QUERY=3
# Isolated eval backends only; production ignores retrieval hints regardless.
ALLOW_EVALUATION_RETRIEVAL_HINTS=false
WIKI_LINK_EXPANSION_PAGES_PER_QUERY=2
KNOWLEDGE_AUTO_INDEX_TTL_SECONDS=604800

# Optional OpenAI-compatible embedding endpoint. When unset, QuestMate keeps
# keyword retrieval enabled but does not create semantic vectors.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
