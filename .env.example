APP_NAME=QuestMate
APP_ENV=development
LOG_LEVEL=info

ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5

TAVILY_API_KEY=your-tavily-api-key

DATABASE_URL=postgresql+asyncpg://questmate:questmate@localhost:5432/questmate
SYNC_DATABASE_URL=postgresql+psycopg://questmate:questmate@localhost:5432/questmate
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,tauri://localhost

SEARCH_MAX_RESULTS=5
CACHE_TTL_SECONDS=604800

# Optional OpenAI-compatible embedding endpoint. When unset, QuestMate keeps
# keyword retrieval enabled but does not create semantic vectors.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
