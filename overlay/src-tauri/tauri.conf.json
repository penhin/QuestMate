{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuestMate Overlay",
  "version": "0.1.0",
  "identifier": "com.questmate.overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QuestMate Overlay",
        "width": 96,
        "height": 96,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBNzRCNkU0NTZDODIxNzkKUldSNUljaFc1TFowcXZLajZHWlN0Ni9kd25mWnlFSGpuMlNBQ1NUQkgyNXhBUjhSY1dINTJub0IK",
      "endpoints": [
        "https://github.com/penhin/QuestMate/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
